{
  "manifest_version": 2,
  "name": "kb_bmstu_lks_fix",
  "version": "1.0.0",
  "description": "Улучшение интерфейса учебного портала МГТУ им. Н.Э. Баумана (Калужский филиал)",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "kb_bmstu_lks_fix"
  },
  "background": {
    "scripts": ["src/background.js"]
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "*://e-learning.bmstu.ru/kaluga/*",
    "https://proxy.bmstu.ru:8443/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://e-learning.bmstu.ru/kaluga/*"],
      "js": [
        "src/content/theme-early.js"
      ],
      "css": [
        "src/styles/theme-override.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": ["*://e-learning.bmstu.ru/kaluga/*"],
      "js": [
        "src/storage.js",
        "src/content/modules/state.js",
        "src/content/modules/utils.js",
        "src/content/modules/theme.js",
        "src/content/modules/compact.js",
        "src/content/modules/course-page.js",
        "src/content/modules/main-page.js",
        "src/content/modules/auto-filename.js",
        "src/content/modules/autologin.js",
        "src/content/modules/messages.js",
        "src/content/init.js"
      ],
      "css": [
        "src/styles/content-elements.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://proxy.bmstu.ru:8443/cas/login*"],
      "js": [
        "src/content/modules/autologin-cas.js"
      ],
      "run_at": "document_start"
    }
  ], [
    "src/styles/theme-override.css"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "kb_bmstu_lks_fix@extension",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
