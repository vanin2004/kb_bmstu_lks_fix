{
  "manifest_version": 2,
  "name": "kb_bmstu_lks_fix",
  "version": "1.0.0",
  "description": "Улучшение интерфейса учебного портала МГТУ им. Н.Э. Баумана (Калужский филиал)",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "kb_bmstu_lks_fix"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "*://e-learning.bmstu.ru/kaluga/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://e-learning.bmstu.ru/kaluga/*"],
      "js": [
        "src/storage.js",
        "src/content/content.js"
      ],
      "css": [
        "src/styles/content-elements.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "src/styles/theme-override.css"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "kb_bmstu_lks_fix@extension",
      "strict_min_version": "57.0"
    }
  }
}
