{
  "manifest_version": 2,
  "name": "kb_bmstu_lks_fix",
  "version": "1.0.0",
  "description": "Расширение для повышения удобства использования ЭОС МГТУ им. Н.Э. Баумана",
  "browser_specific_settings": {
    "gecko": {
      "id": "compact-univer@bmstu.ru",
      "strict_min_version": "78.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Настройки kb_bmstu_lks_fix"
  },
  "permissions": [
    "storage",
    "activeTab",
    "https://e-learning.bmstu.ru/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://e-learning.bmstu.ru/kaluga/*"],
      "js": ["src/content/early.js"],
      "css": ["src/styles/base-fixes.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://e-learning.bmstu.ru/kaluga/*"],
      "js": [
        "src/content/modules/storage-adapter.js",
        "src/content/modules/compact-mode.js",
        "src/content/modules/items-manager.js",
        "src/content/modules/customization-manager.js",
        "src/content/modules/theme-manager.js",
        "src/content/main.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": ["src/styles/*.css"]
}
